# Root env for docker compose (api + db). The web/ frontend has its own config.

# Postgres password (used by the db service and the DATABASE_URL below)
POSTGRES_PASSWORD="rackside"

# SQLAlchemy connection (host "db" is the compose service)
DATABASE_URL="postgresql+psycopg://rackside:rackside@db:5432/rackside"

# JWT signing secret for admin sessions
SECRET_KEY="change-me-to-a-long-random-string"

# Stripe (test mode)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public URL of the Astro frontend (CORS + Stripe redirect targets)
FRONTEND_URL="http://localhost:4321"

# Seeded admin account
ADMIN_EMAIL="admin@rackside.app"
ADMIN_PASSWORD="rackside-admin"
