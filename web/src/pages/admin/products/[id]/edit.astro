---
import Layout from "@/layouts/Layout.astro";
import AdminNav from "@/components/AdminNav.astro";
import ProductForm from "@/components/ProductForm.astro";
import { getAdminProduct } from "@/lib/api";
import { getToken, clearToken } from "@/lib/auth";

const token = getToken(Astro.cookies)!;
const { id } = Astro.params;
const product = await getAdminProduct(token, id!);

if (product === null) {
  clearToken(Astro.cookies);
  return Astro.redirect("/admin/login");
}
---

<Layout title="Edit product — Rackside Admin">
  <section class="wrap admin">
    <AdminNav />
    <h1>Edit product</h1>
    <ProductForm action={`/api/admin/products/${id}/update`} product={product} />
  </section>
</Layout>

<style>
  .admin {
    padding: 2.5rem 0;
  }
  .admin h1 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }
</style>
