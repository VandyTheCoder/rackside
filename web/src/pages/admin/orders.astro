---
import Layout from "@/layouts/Layout.astro";
import AdminNav from "@/components/AdminNav.astro";
import { getAdminOrders } from "@/lib/api";
import { getToken, clearToken } from "@/lib/auth";
import { formatPrice } from "@/lib/money";

const token = getToken(Astro.cookies)!;
const orders = await getAdminOrders(token);

if (orders === null) {
  clearToken(Astro.cookies);
  return Astro.redirect("/admin/login");
}
---

<Layout title="Orders — Rackside Admin">
  <section class="wrap admin">
    <AdminNav />
    <h1>Orders</h1>
    {
      orders.length === 0 ? (
        <p class="muted">No orders yet.</p>
      ) : (
        <ul class="orders">
          {orders.map((order) => (
            <li class="panel order">
              <div class="order-head">
                <span class="email">{order.email}</span>
                <span class="amount">{formatPrice(order.amount_cents)}</span>
              </div>
              <p class="meta">
                {new Date(order.created_at).toLocaleString()} · {order.status}
              </p>
              <ul class="lines">
                {order.items.map((item) => (
                  <li>
                    {item.quantity} × {item.name}
                  </li>
                ))}
              </ul>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>

<style>
  .admin {
    padding: 2.5rem 0;
  }
  .admin h1 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }
  .muted {
    color: var(--chalk-dim);
  }
  .orders {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .order {
    padding: 1.3rem 1.5rem;
  }
  .order-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .email {
    font-weight: 600;
  }
  .amount {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--brass-bright);
  }
  .meta {
    color: var(--chalk-faint);
    font-size: 0.82rem;
    margin: 0.3rem 0 0.8rem;
  }
  .lines {
    list-style: none;
    margin: 0;
    padding: 0;
    color: var(--chalk-dim);
    font-size: 0.92rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
</style>
