---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Your cart — Rackside">
  <section class="wrap cart">
    <h1>Your cart</h1>
    <div id="cart-root" class="cart-root">
      <p class="muted">Loading…</p>
    </div>
  </section>
</Layout>

<script>
  import {
    getCart,
    setQuantity,
    removeItem,
    cartTotal,
  } from "@/scripts/cart";
  import { formatPrice } from "@/lib/money";

  const root = document.getElementById("cart-root")!;

  function render() {
    const items = getCart();
    if (items.length === 0) {
      root.innerHTML = `
        <div class="empty panel">
          <p class="muted">Your cart is empty.</p>
          <a href="/" class="btn btn-ghost">Browse the rack</a>
        </div>`;
      return;
    }

    const rows = items
      .map(
        (item) => `
        <li class="row">
          <div>
            <p class="row-name">${item.name}</p>
            <p class="muted">${formatPrice(item.price_cents)}</p>
          </div>
          <div class="row-controls">
            <input class="field qty" type="number" min="1" max="99"
              value="${item.quantity}" data-slug="${item.slug}" aria-label="Quantity" />
            <button class="link-remove" data-remove="${item.slug}">Remove</button>
          </div>
        </li>`,
      )
      .join("");

    root.innerHTML = `
      <ul class="rows panel">${rows}</ul>
      <div class="summary">
        <span class="total-label">Total</span>
        <span class="total">${formatPrice(cartTotal())}</span>
      </div>
      <p id="cart-error" class="error" hidden></p>
      <div class="cart-actions">
        <button id="checkout" class="btn btn-brass"><span class="btn-label">Checkout</span></button>
      </div>`;

    root.querySelectorAll<HTMLInputElement>(".qty").forEach((input) => {
      input.addEventListener("change", () => {
        setQuantity(input.dataset.slug!, Number(input.value));
        render();
      });
    });
    root.querySelectorAll<HTMLButtonElement>("[data-remove]").forEach((button) => {
      button.addEventListener("click", () => {
        removeItem(button.dataset.remove!);
        render();
      });
    });

    const checkout = document.getElementById("checkout") as HTMLButtonElement;
    const error = document.getElementById("cart-error")!;
    checkout.addEventListener("click", async () => {
      checkout.disabled = true;
      error.hidden = true;
      try {
        const response = await fetch("/api/checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            items: getCart().map((item) => ({
              slug: item.slug,
              quantity: item.quantity,
            })),
          }),
        });
        const data = await response.json();
        if (!response.ok || !data.url) throw new Error(data.error ?? "Checkout failed");
        window.location.href = data.url;
      } catch (cause) {
        error.textContent =
          cause instanceof Error ? cause.message : "Checkout failed";
        error.hidden = false;
        checkout.disabled = false;
      }
    });
  }

  render();
  window.addEventListener("cart:change", render);
</script>

<style>
  .cart {
    padding: 3rem 0;
  }
  .cart h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 1.8rem;
  }
  .muted {
    color: var(--chalk-dim);
  }
  .cart-root :global(.rows) {
    list-style: none;
    margin: 0;
    padding: 0.4rem 0;
  }
  .cart-root :global(.row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.3rem;
    border-bottom: 1px solid var(--line);
  }
  .cart-root :global(.row:last-child) {
    border-bottom: none;
  }
  .cart-root :global(.row-name) {
    font-weight: 600;
    margin: 0 0 0.2rem;
  }
  .cart-root :global(.row-controls) {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .cart-root :global(.qty) {
    width: 70px;
    text-align: center;
  }
  .cart-root :global(.link-remove) {
    background: none;
    border: none;
    color: var(--chalk-faint);
    cursor: pointer;
    font-size: 0.85rem;
  }
  .cart-root :global(.link-remove:hover) {
    color: #e0625a;
  }
  .cart-root :global(.summary) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 1.5rem 0;
  }
  .cart-root :global(.total) {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--brass-bright);
  }
  .cart-root :global(.cart-actions) {
    display: flex;
    justify-content: flex-end;
  }
  .cart-root :global(.empty) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding: 2rem;
  }
  .cart-root :global(.error) {
    color: #e0625a;
    margin-bottom: 1rem;
  }
</style>
