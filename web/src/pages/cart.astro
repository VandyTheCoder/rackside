---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Your cart — Rackside">
  <section class="wrap cart">
    <h1>Your cart</h1>
    <div id="cart-root" class="cart-root">
      <p class="muted">Loading…</p>
    </div>
  </section>
</Layout>

<script>
  import {
    getCart,
    setQuantity,
    removeItem,
    cartTotal,
  } from "@/scripts/cart";
  import { formatPrice } from "@/lib/money";

  const root = document.getElementById("cart-root")!;

  const minusIcon =
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14"/></svg>';
  const plusIcon =
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>';
  const trashIcon =
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M10 11v6M14 11v6M5 7l1 13a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1l1-13M9 7V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3"/></svg>';

  function render() {
    const items = getCart();
    if (items.length === 0) {
      root.innerHTML = `
        <div class="empty panel">
          <p class="muted">Your cart is empty.</p>
          <a href="/" class="btn btn-ghost">Browse the rack</a>
        </div>`;
      return;
    }

    const rows = items
      .map(
        (item) => `
        <li class="row">
          <div class="row-info">
            <p class="row-name">${item.name}</p>
            <p class="muted">${formatPrice(item.price_cents)} each</p>
          </div>
          <div class="row-controls">
            <div class="stepper">
              <button class="step" data-dec="${item.slug}" aria-label="Decrease quantity">${minusIcon}</button>
              <span class="qty-val">${item.quantity}</span>
              <button class="step" data-inc="${item.slug}" aria-label="Increase quantity">${plusIcon}</button>
            </div>
            <span class="line-total">${formatPrice(item.price_cents * item.quantity)}</span>
            <button class="remove" data-remove="${item.slug}" aria-label="Remove ${item.name}">${trashIcon}</button>
          </div>
        </li>`,
      )
      .join("");

    root.innerHTML = `
      <ul class="rows panel">${rows}</ul>
      <div class="summary">
        <span class="total-label">Total</span>
        <span class="total">${formatPrice(cartTotal())}</span>
      </div>
      <p id="cart-error" class="error" hidden></p>
      <div class="cart-actions">
        <button id="checkout" class="btn btn-brass"><span class="btn-label">Checkout</span></button>
      </div>`;

    const qtyOf = (slug: string) =>
      getCart().find((entry) => entry.slug === slug)?.quantity ?? 1;

    root.querySelectorAll<HTMLButtonElement>("[data-inc]").forEach((button) => {
      button.addEventListener("click", () => {
        const slug = button.dataset.inc!;
        setQuantity(slug, Math.min(99, qtyOf(slug) + 1));
        render();
      });
    });
    root.querySelectorAll<HTMLButtonElement>("[data-dec]").forEach((button) => {
      button.addEventListener("click", () => {
        const slug = button.dataset.dec!;
        setQuantity(slug, Math.max(1, qtyOf(slug) - 1));
        render();
      });
    });
    root.querySelectorAll<HTMLButtonElement>("[data-remove]").forEach((button) => {
      button.addEventListener("click", () => {
        removeItem(button.dataset.remove!);
        render();
      });
    });

    const checkout = document.getElementById("checkout") as HTMLButtonElement;
    const error = document.getElementById("cart-error")!;
    checkout.addEventListener("click", async () => {
      checkout.disabled = true;
      error.hidden = true;
      try {
        const response = await fetch("/api/checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            items: getCart().map((item) => ({
              slug: item.slug,
              quantity: item.quantity,
            })),
          }),
        });
        const data = await response.json();
        if (!response.ok || !data.url) throw new Error(data.error ?? "Checkout failed");
        window.location.href = data.url;
      } catch (cause) {
        error.textContent =
          cause instanceof Error ? cause.message : "Checkout failed";
        error.hidden = false;
        checkout.disabled = false;
      }
    });
  }

  render();
  window.addEventListener("cart:change", render);
</script>

<style>
  .cart {
    padding: 3rem 0;
  }
  .cart h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 1.8rem;
  }
  .muted {
    color: var(--chalk-dim);
  }
  .cart-root :global(.rows) {
    list-style: none;
    margin: 0;
    padding: 0.4rem 0;
  }
  .cart-root :global(.row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.3rem;
    border-bottom: 1px solid var(--line);
  }
  .cart-root :global(.row:last-child) {
    border-bottom: none;
  }
  .cart-root :global(.row-name) {
    font-weight: 600;
    margin: 0 0 0.2rem;
  }
  .cart-root :global(.row-info .muted) {
    font-size: 0.82rem;
  }
  .cart-root :global(.row-controls) {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  /* Quantity stepper */
  .cart-root :global(.stepper) {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    background: rgba(4, 16, 10, 0.5);
    overflow: hidden;
  }
  .cart-root :global(.step) {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border: none;
    background: transparent;
    color: var(--chalk-dim);
    cursor: pointer;
    transition: background 0.18s, color 0.18s;
  }
  .cart-root :global(.step:hover) {
    background: rgba(201, 162, 74, 0.16);
    color: var(--brass-bright);
  }
  .cart-root :global(.step:active) {
    transform: scale(0.92);
  }
  .cart-root :global(.step svg) {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .cart-root :global(.qty-val) {
    min-width: 2ch;
    text-align: center;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .cart-root :global(.line-total) {
    font-family: var(--font-display);
    font-size: 1.1rem;
    min-width: 5ch;
    text-align: right;
  }

  /* Remove (trash) */
  .cart-root :global(.remove) {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1px solid transparent;
    border-radius: 999px;
    background: transparent;
    color: var(--chalk-faint);
    cursor: pointer;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
  }
  .cart-root :global(.remove:hover) {
    color: #e0625a;
    border-color: rgba(224, 98, 90, 0.4);
    background: rgba(224, 98, 90, 0.1);
  }
  .cart-root :global(.remove svg) {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .cart-root :global(.summary) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 1.5rem 0;
  }
  .cart-root :global(.total) {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--brass-bright);
  }
  .cart-root :global(.cart-actions) {
    display: flex;
    justify-content: flex-end;
  }
  .cart-root :global(.empty) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding: 2rem;
  }
  .cart-root :global(.error) {
    color: #e0625a;
    margin-bottom: 1rem;
  }

  @media (max-width: 560px) {
    .cart-root :global(.row) {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.8rem;
    }
    .cart-root :global(.row-controls) {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
