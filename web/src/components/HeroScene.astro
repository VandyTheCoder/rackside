---
const COLORS: Record<number, string> = {
  1: "#f4c430", 2: "#1f6feb", 3: "#d7263d", 4: "#7b2cbf", 5: "#e8682c",
  6: "#1a8a60", 7: "#9b1d3a", 8: "#0a0a0a", 9: "#f4c430", 10: "#1f6feb",
  11: "#d7263d", 12: "#7b2cbf", 13: "#e8682c", 14: "#1a8a60", 15: "#9b1d3a",
};

const r = 15;
const rackX = 96;
const rackCY = 190;

type Ball = { x: number; y: number; n: number; color: string; striped: boolean };
const balls: Ball[] = [];
let n = 1;
for (let col = 0; col < 5; col += 1) {
  const count = 5 - col;
  const x = rackX + col * (r * 1.74);
  for (let k = 0; k < count; k += 1) {
    const y = rackCY + (k - (count - 1) / 2) * (r * 2 + 1);
    balls.push({ x, y, n, color: COLORS[n], striped: n > 8 });
    n += 1;
  }
}

const pockets = [
  [34, 34], [280, 28], [526, 34],
  [34, 346], [280, 352], [526, 346],
];
---

<svg class="hero-scene" viewBox="0 0 560 380" role="img" aria-label="Top-down billiards table with a racked set of balls and crossed cues">
  <defs>
    <linearGradient id="cue" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#5a3413" />
      <stop offset="45%" stop-color="#c98a3f" />
      <stop offset="100%" stop-color="#e9c178" />
    </linearGradient>
    <radialGradient id="cueball" cx="36%" cy="30%" r="72%">
      <stop offset="0%" stop-color="#ffffff" />
      <stop offset="72%" stop-color="#f1ece0" />
      <stop offset="100%" stop-color="#c7bfa9" />
    </radialGradient>
    {
      balls.map((b) => (
        <radialGradient id={`g${b.n}`} cx="36%" cy="30%" r="74%">
          <stop offset="0%" stop-color="#ffffff" stop-opacity="0.85" />
          <stop offset="26%" stop-color={b.striped ? "#f6f3ea" : b.color} />
          <stop offset="100%" stop-color="#0c0c0c" />
        </radialGradient>
      ))
    }
  </defs>

  <!-- wood rail -->
  <rect x="2" y="2" width="556" height="376" rx="34" fill="#7c4012" />
  <rect x="8" y="8" width="544" height="364" rx="30" fill="#b5651d" />
  <!-- felt -->
  <rect x="30" y="30" width="500" height="320" rx="14" fill="#16834a" />
  <rect x="30" y="30" width="500" height="320" rx="14" fill="#000" opacity="0.06" />

  <!-- pockets -->
  {pockets.map(([px, py]) => <circle cx={px} cy={py} r="17" fill="#0c0c0c" />)}

  <!-- crossed cues -->
  <g stroke-linecap="round">
    <line x1="250" y1="64" x2="528" y2="300" stroke="url(#cue)" stroke-width="11" />
    <line x1="250" y1="316" x2="528" y2="78" stroke="url(#cue)" stroke-width="11" />
    <circle cx="252" cy="66" r="4.5" fill="#1f6feb" />
    <circle cx="252" cy="314" r="4.5" fill="#1f6feb" />
  </g>

  <!-- cue ball -->
  <ellipse cx="392" cy="206" rx="15" ry="5" fill="#000" opacity="0.25" />
  <circle cx="392" cy="196" r="15" fill="url(#cueball)" />

  <!-- racked balls -->
  {
    balls.map((b) => (
      <g>
        <ellipse cx={b.x} cy={b.y + r + 3} rx={r - 2} ry="4" fill="#000" opacity="0.2" />
        <circle cx={b.x} cy={b.y} r={r} fill={`url(#g${b.n})`} />
        {b.striped && (
          <path
            d={`M ${b.x - r} ${b.y} a ${r} ${r} 0 0 0 ${r * 2} 0 Z`}
            fill={b.color}
            opacity="0.92"
            transform={`rotate(-10 ${b.x} ${b.y})`}
          />
        )}
        <circle cx={b.x} cy={b.y + 1} r={r * 0.44} fill="#f6f3ea" />
        <text
          x={b.x} y={b.y + 1}
          text-anchor="middle" dominant-baseline="central"
          font-family="Georgia, serif" font-size="14" font-weight="700" fill="#0a0a0a">{b.n}</text>
        <ellipse cx={b.x - r * 0.32} cy={b.y - r * 0.4} rx={r * 0.28} ry={r * 0.16} fill="#fff" opacity="0.5" />
      </g>
    ))
  }
</svg>

<style>
  .hero-scene {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 26px 44px rgba(0, 0, 0, 0.4));
  }
</style>
